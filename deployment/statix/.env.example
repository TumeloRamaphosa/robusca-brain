# StudEx / NestVM — local secrets (NEVER commit)
# Copy to .env.local and fill in values:
#   cp .env.example .env.local

# Orgo.ai — https://orgo.ai/start
ORGO_API_KEY=
ORGO_COMPUTER_ID=333de3f8-0801-430b-a541-aad458e896b5
ORGO_WORKSPACE_ID=

# Cloudflare — https://dash.cloudflare.com/profile/api-tokens
# Create token: Zone → DNS → Edit (scoped to studex-group.com)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=0b15cf80f76fc28d4ec56c5d211b9f1b

# Cloudflare Tunnel — Zero Trust → Networks → Tunnels → studex-nestvm → Install connector
CLOUDFLARE_TUNNEL_TOKEN=

# Orgo VM public IP
ORGO_VM_IP=

# DNS target — studex-group.com subdomains (no tenant wildcards)
STATIX_DOMAIN=studex.studex-group.com
# agent.studex-group.com and www.agent.studex-group.com set by cloudflare-studex-dns.sh

# StudEx app
PORT=5181
NODE_ENV=development

# Desktop demo — Ollama brain (local or Tailscale inference node)
OLLAMA_HOST=http://127.0.0.1:11434
DEMO_MODEL=qwen2.5:3b
# Windows Ornith node over Tailscale:
# OLLAMA_HOST=http://100.x.x.x:11434
# DEMO_MODEL=hf.co/deepreinforce-ai/Ornith-1.0-35B-GGUF:Q4_K_M
# Cloud alternative: DEMO_MODEL=nemotron-3-super:cloud

# SEO Office (seo-os) — companies + people brain vault
# Run: git clone https://github.com/AgriciDaniel/seo-os.git && pnpm dev (port 3000)
SEO_OFFICE_URL=http://localhost:3000
# Optional — client-side link to 3D office (defaults to SEO_OFFICE_URL)
# VITE_SEO_OFFICE_URL=http://localhost:3000

# Optional — OpenAI for future voice realtime
# OPENAI_API_KEY=
