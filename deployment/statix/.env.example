# Statix / NestVM — local secrets (NEVER commit)
# Copy to .env.local and fill in values:
#   cp .env.example .env.local

# Orgo.ai — https://orgo.ai/start
ORGO_API_KEY=
ORGO_COMPUTER_ID=946b3156-cab9-4187-a94b-056dfab35105
ORGO_WORKSPACE_ID=

# Cloudflare — https://dash.cloudflare.com/profile/api-tokens
# Create token: Zone DNS Edit for statix.com
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# Statix app
PORT=5180
NODE_ENV=production

# SEO Office (seo-os) — companies + people brain vault
# Run: git clone https://github.com/AgriciDaniel/seo-os.git && pnpm dev (port 3000)
SEO_OFFICE_URL=http://localhost:3000
# Optional — client-side link to 3D office (defaults to SEO_OFFICE_URL)
# VITE_SEO_OFFICE_URL=http://localhost:3000

# Optional — OpenAI for future voice realtime
# OPENAI_API_KEY=
