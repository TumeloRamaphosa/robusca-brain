{
  "name": "statix-nestvm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite --host 0.0.0.0 --port 5180\" \"tsx watch server/index.ts\"",
    "build": "vite build --outDir dist/client && esbuild server/index.ts --bundle --platform=node --format=esm --outfile=dist/server.js --packages=external",
    "start": "NODE_ENV=production node dist/server.js",
    "preview": "vite preview --host 0.0.0.0 --port 5180"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.0.1",
    "lucide-react": "^0.453.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "wouter": "^3.3.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^20.19.27",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.0.1",
    "esbuild": "^0.25.0",
    "tsx": "^4.20.5",
    "typescript": "^5.6.3",
    "vite": "^6.0.0"
  }
}
