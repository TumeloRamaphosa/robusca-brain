# Secrets — copy to `.env.local` (gitignored). NEVER commit real values.
# Paste keys only into the vault / local env — never into chat or git.

# Composio action layer (https://app.composio.dev)
COMPOSIO_API_KEY=

# Sent.dm messaging (https://www.sent.dm) — SMS / WhatsApp / RCS
SENT_DM_API_KEY=
SENT_DM_WEBHOOK_SECRET=
SENT_DM_PARCEL_TEMPLATE_ID=

# Optional
# COMPOSIO_BASE_URL=https://backend.composio.dev
# COMPOSIO_LOG_LEVEL=info
