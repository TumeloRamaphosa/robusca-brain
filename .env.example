# Copy to a local-only secret store / shell profile — NEVER commit real values.
# NotebookLM has no official API. Auth is Google session cookies.

# Preferred: run `nlm login` once on a machine with a browser (stores cookies
# under ~/.notebooklm-mcp-cli/). Leave NOTEBOOKLM_COOKIES unset.

# Fallback (headless / CI): paste the FULL cookie header from DevTools
# (Network → batchexecute → Request Headers → cookie:). Must look like:
#   SID=...; HSID=...; SSID=...; APISID=...; SAPISID=...; __Secure-1PSID=...
# A lone AQ.* token is NOT enough.
# NOTEBOOKLM_COOKIES=

# Default notebook for Studex agents (from owner-provided URL)
NOTEBOOKLM_DEFAULT_NOTEBOOK_ID=98636c01-c524-4ff8-a9f6-05770487a7ec
